{
  "name": "codespark-agent",
  "displayName": "CodeSpark",
  "description": "The inline agent for writing code.",
  "version": "0.1.3",
  "publisher": "codespark",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/christianalfoni/codespark"
  },
  "keywords": [
    "ai",
    "inline",
    "agent",
    "code generation",
    "copilot",
    "anthropic",
    "openai"
  ],
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeSpark.invoke",
        "title": "CodeSpark: Invoke"
      },
      {
        "command": "codeSpark.showStats",
        "title": "CodeSpark: Show Stats"
      },
      {
        "command": "codeSpark.resetStats",
        "title": "CodeSpark: Reset Stats"
      }
    ],
    "keybindings": [
      {
        "command": "codeSpark.invoke",
        "key": "cmd+i",
        "when": "editorTextFocus"
      },
      {
        "command": "codeSpark.acceptDiff",
        "key": "cmd+enter",
        "when": "editorTextFocus && codeSpark.hasPendingDiff"
      },
      {
        "command": "codeSpark.rejectDiff",
        "key": "cmd+backspace",
        "when": "editorTextFocus && codeSpark.hasPendingDiff"
      }
    ],
    "colors": [],
    "configuration": {
      "title": "CodeSpark",
      "properties": {
        "codeSpark.provider": {
          "type": "string",
          "enum": [
            "copilot",
            "anthropic",
            "openai",
            "google",
            "openrouter",
            "groq",
            "xai",
            "mistral",
            "together"
          ],
          "default": "copilot",
          "markdownDescription": "AI provider. **Copilot** uses your GitHub Copilot subscription (no API key needed). All others require an API key."
        },
        "codeSpark.model": {
          "type": "string",
          "default": "",
          "markdownDescription": "Model to use. Leave empty for a sensible default per provider."
        },
        "codeSpark.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "API key for the selected provider. Not required for Copilot."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "compile": "tsc -p ./ --noEmit",
    "lint": "eslint src --ext ts",
    "package": "npx @vscode/vsce package",
    "publish": "npx @vscode/vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.91.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.92",
    "@anthropic-ai/claude-code": "^2.1.92",
    "@mariozechner/pi-agent-core": "^0.65.0",
    "@mariozechner/pi-ai": "^0.65.0",
    "@mariozechner/pi-coding-agent": "^0.65.0"
  }
}
