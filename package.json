{
  "name": "codespark-agent",
  "displayName": "CodeSpark",
  "description": "A coding agent at the tip of your cursor",
  "version": "0.7.1",
  "publisher": "codespark",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/christianalfoni/codespark"
  },
  "keywords": [
    "ai",
    "inline",
    "agent",
    "code generation",
    "copilot",
    "anthropic",
    "openai"
  ],
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "codeSpark",
          "title": "CODESPARK",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "codeSpark": [
        {
          "id": "codeSpark.research",
          "name": "Research",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "codeSpark.invoke",
        "title": "CodeSpark: Invoke"
      },
      {
        "command": "codeSpark.showStats",
        "title": "CodeSpark: Show Stats"
      },
      {
        "command": "codeSpark.resetStats",
        "title": "CodeSpark: Reset Stats"
      },
      {
        "command": "codeSpark.clearResearchSummary",
        "title": "CodeSpark: Clear Research Summary"
      },
      {
        "command": "codeSpark.openResearch",
        "title": "CodeSpark: Open Research"
      }
    ],
    "keybindings": [
      {
        "command": "codeSpark.invoke",
        "mac": "cmd+i",
        "win": "ctrl+i",
        "linux": "ctrl+i",
        "when": "editorTextFocus"
      },
      {
        "command": "codeSpark.openResearch",
        "mac": "cmd+shift+i",
        "win": "ctrl+shift+i",
        "linux": "ctrl+shift+i"
      }
    ],
    "colors": [],
    "configuration": {
      "title": "CodeSpark",
      "properties": {
        "codeSpark.provider": {
          "type": "string",
          "enum": [
            "copilot",
            "anthropic",
            "openai",
            "google",
            "openrouter",
            "groq",
            "xai",
            "mistral",
            "together"
          ],
          "default": "copilot",
          "markdownDescription": "AI provider. **Copilot** uses your GitHub Copilot subscription (no API key needed). All others require an API key."
        },
        "codeSpark.model": {
          "type": "string",
          "default": "",
          "markdownDescription": "Model to use. Leave empty for a sensible default per provider."
        },
        "codeSpark.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "API key for the selected provider. Not required for Copilot."
        },
        "codeSpark.researchModel": {
          "type": "string",
          "default": "",
          "markdownDescription": "Model for the research agent's head (orchestrator). Defaults to a smarter model per provider (e.g. Sonnet). The sub-agents use `#codeSpark.model#`."
        },
        "codeSpark.braveApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "API key for [Brave Search](https://brave.com/search/api/). Required for the research agent's web search."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "compile": "tsc -p ./ --noEmit",
    "lint": "eslint src --ext ts",
    "package": "npx @vscode/vsce package",
    "publish": "npx @vscode/vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.91.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.65.0",
    "@mariozechner/pi-ai": "^0.65.0",
    "@mariozechner/pi-coding-agent": "^0.65.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.0",
    "preact": "^10.29.1"
  }
}
