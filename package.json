{
  "name": "codespark-agent",
  "displayName": "CodeSpark",
  "description": "A coding agent where you still code",
  "version": "0.25.10",
  "publisher": "codespark",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/christianalfoni/codespark"
  },
  "keywords": [
    "ai",
    "inline",
    "agent",
    "code generation",
    "copilot",
    "anthropic",
    "openai"
  ],
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "codeSpark",
          "title": "CODESPARK",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "codeSpark": [
        {
          "id": "codeSpark.assistant",
          "name": "Assistant",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "codeSpark.showStats",
        "title": "CodeSpark: Show Stats"
      },
      {
        "command": "codeSpark.resetStats",
        "title": "CodeSpark: Reset Stats"
      },
      {
        "command": "codeSpark.clearAssistantSummary",
        "title": "CodeSpark: Clear Assistant Summary"
      },
      {
        "command": "codeSpark.openAssistant",
        "title": "CodeSpark: Open Assistant"
      }
    ],
    "keybindings": [
      {
        "command": "codeSpark.openAssistant",
        "mac": "cmd+shift+i",
        "win": "ctrl+shift+i",
        "linux": "ctrl+shift+i"
      }
    ],
    "colors": [],
    "configuration": {
      "title": "CodeSpark",
      "properties": {
        "codeSpark.experiments.stackedCommits": {
          "type": "boolean",
          "default": false,
          "description": "Enable the 'Stack commits' action that splits uncommitted changes into one commit per breakdown step. Requires a window reload to take effect."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "compile": "tsc -p ./ --noEmit",
    "lint": "eslint src --ext ts",
    "package": "npx @vscode/vsce package",
    "publish": "npx @vscode/vsce publish"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.91.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "diff": "^8.0.4",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.0",
    "preact": "^10.29.1",
    "zod": "^3.24.4"
  }
}
