{
  "name": "codespark-agent",
  "displayName": "CodeSpark",
  "description": "A coding agent at the tip of your cursor",
  "version": "0.13.0",
  "publisher": "codespark",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/christianalfoni/codespark"
  },
  "keywords": [
    "ai",
    "inline",
    "agent",
    "code generation",
    "copilot",
    "anthropic",
    "openai"
  ],
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "codeSpark",
          "title": "CODESPARK",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "codeSpark": [
        {
          "id": "codeSpark.research",
          "name": "Research",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "codeSpark.invoke",
        "title": "CodeSpark: Invoke"
      },
      {
        "command": "codeSpark.showStats",
        "title": "CodeSpark: Show Stats"
      },
      {
        "command": "codeSpark.resetStats",
        "title": "CodeSpark: Reset Stats"
      },
      {
        "command": "codeSpark.clearResearchSummary",
        "title": "CodeSpark: Clear Research Summary"
      },
      {
        "command": "codeSpark.openResearch",
        "title": "CodeSpark: Open Research"
      }
    ],
    "keybindings": [
      {
        "command": "codeSpark.invoke",
        "mac": "cmd+i",
        "win": "ctrl+i",
        "linux": "ctrl+i",
        "when": "editorTextFocus"
      },
      {
        "command": "codeSpark.openResearch",
        "mac": "cmd+shift+i",
        "win": "ctrl+shift+i",
        "linux": "ctrl+shift+i"
      }
    ],
    "colors": [],
    "configuration": {
      "title": "CodeSpark",
      "properties": {}
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "compile": "tsc -p ./ --noEmit",
    "lint": "eslint src --ext ts",
    "package": "npx @vscode/vsce package",
    "publish": "npx @vscode/vsce publish"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.91.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "diff": "^8.0.4",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.0",
    "preact": "^10.29.1",
    "zod": "^3.24.4"
  }
}
